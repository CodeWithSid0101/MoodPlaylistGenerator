# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/spotify-playlist?retryWrites=true&w=majority

# JWT Secret (Generate a random string)
JWT_SECRET=your-super-secret-jwt-key-make-it-very-long-and-random-12345

# Spotify API Credentials (Get from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=https://your-app-name.onrender.com/api/spotify/callback

# OpenWeather API Key
OPENWEATHER_API_KEY=81165c8839597701582170a90141d335

# Admin Account
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=SecureAdminPassword123

# Application Environment
NODE_ENV=production
PORT=3000

# Optional: Application URL (for redirects)
APP_URL=https://your-app-name.onrender.com